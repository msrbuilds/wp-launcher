# WP Launcher Environment Configuration

# Node environment
NODE_ENV=development

# Base domain for the launcher (subdomains will be *.BASE_DOMAIN)
BASE_DOMAIN=localhost

# API authentication key (used for admin dashboard)
API_KEY=change-me-to-a-secure-random-string

# JWT secret for user authentication
JWT_SECRET=change-me-to-a-secure-random-string
JWT_EXPIRES_IN=7d

# Public URL (used in verification emails)
PUBLIC_URL=http://localhost

# SMTP Configuration (for sending verification emails)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-smtp-user
SMTP_PASS=your-smtp-password
SMTP_FROM=WP Launcher <noreply@example.com>

# WordPress image name (built by build-wp-image script)
WP_IMAGE=wp-launcher/wordpress:latest

# Optional: Cloudflare DNS for Let's Encrypt wildcard certs
# CF_API_EMAIL=your@email.com
# CF_DNS_API_TOKEN=your-cloudflare-api-token
