# WP Launcher Environment Configuration
# Copy this to .env and fill in your values, or run: bash install.sh

# ─── Core ────────────────────────────────────────────────────────────────────
NODE_ENV=production

# Base domain (subdomains will be *.BASE_DOMAIN)
BASE_DOMAIN=demo.example.com

# Public URL (used in verification emails and links)
PUBLIC_URL=https://demo.example.com

# ─── Secrets (generate strong random values!) ────────────────────────────────
# API key for admin access
API_KEY=change-me-to-a-secure-random-string

# JWT secret for user authentication tokens
JWT_SECRET=change-me-to-a-secure-random-string

# Internal key for API <-> Provisioner communication
PROVISIONER_INTERNAL_KEY=change-me-to-a-secure-random-string

# JWT token lifetime
JWT_EXPIRES_IN=7d

# ─── CORS ────────────────────────────────────────────────────────────────────
# Allowed origins (comma-separated). Leave empty to use BASE_DOMAIN default.
CORS_ALLOWED_ORIGINS=https://demo.example.com

# ─── SMTP (for sending verification emails) ─────────────────────────────────
# Set to "mailpit" / port 1025 for local dev (uses built-in Mailpit)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-smtp-user
SMTP_PASS=your-smtp-password
SMTP_FROM=WP Launcher <noreply@demo.example.com>

# ─── WordPress ───────────────────────────────────────────────────────────────
# Docker image for demo sites (built by scripts/build-wp-image.sh)
WP_IMAGE=wp-launcher/wordpress:latest

# Per-container resource limits
CONTAINER_MEMORY=268435456
CONTAINER_CPU=0.5

# ─── Let's Encrypt SSL ──────────────────────────────────────────────────────
# Email for Let's Encrypt certificate notifications
ACME_EMAIL=your@email.com

# ─── Cloudflare (optional — for wildcard SSL via DNS challenge) ──────────────
# Uncomment and fill in if using Cloudflare DNS challenge (recommended)
# CF_API_EMAIL=your@email.com
# CF_DNS_API_TOKEN=your-cloudflare-api-token
