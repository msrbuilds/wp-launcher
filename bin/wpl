#!/bin/bash
###############################################################################
# wpl — WP Launcher CLI
#
# Global command to manage WP Launcher from anywhere.
# Install: bash install-local.sh (auto-installs) or manually:
#   ln -sf /path/to/wp-launcher/bin/wpl /usr/local/bin/wpl
###############################################################################
set -euo pipefail

# Resolve the project directory (where docker-compose.yml lives)
# First check if WPL_DIR is set, then try to find it relative to this script
if [ -n "${WPL_DIR:-}" ]; then
  PROJECT_DIR="$WPL_DIR"
elif [ -L "${BASH_SOURCE[0]}" ]; then
  # Follow symlink to find the real script location
  REAL_SCRIPT="$(readlink -f "${BASH_SOURCE[0]}")"
  PROJECT_DIR="$(cd "$(dirname "$REAL_SCRIPT")/.." && pwd)"
else
  PROJECT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
fi

# Verify project directory
if [ ! -f "$PROJECT_DIR/docker-compose.yml" ]; then
  echo "Error: Could not find WP Launcher project directory."
  echo "Set WPL_DIR environment variable to your wp-launcher path."
  echo "  export WPL_DIR=/path/to/wp-launcher"
  exit 1
fi

# Load .env for API_PORT
[ -f "$PROJECT_DIR/.env" ] && export $(grep -v '^#' "$PROJECT_DIR/.env" | xargs 2>/dev/null) || true
API_PORT="${API_PORT:-3737}"

# Delegate to Node.js CLI if built (supports dashboard TUI)
NODE_CLI="$PROJECT_DIR/packages/cli/dist/index.js"
if [ -f "$NODE_CLI" ] && command -v node &>/dev/null; then
  WPL_DIR="$PROJECT_DIR" exec node "$NODE_CLI" "$@"
fi

# Ensure Docker daemon is running, start Docker Desktop if needed
ensure_docker() {
  if docker info &>/dev/null 2>&1; then
    return 0
  fi

  echo "Docker is not running. Starting Docker Desktop..."

  case "$(uname -s)" in
    MINGW*|MSYS*|CYGWIN*)
      # Windows: try common Docker Desktop paths
      local dd=""
      for p in \
        "$PROGRAMFILES/Docker/Docker/Docker Desktop.exe" \
        "$LOCALAPPDATA/Docker/Docker Desktop.exe" \
        "/c/Program Files/Docker/Docker/Docker Desktop.exe"; do
        if [ -f "$p" ]; then dd="$p"; break; fi
      done
      if [ -n "$dd" ]; then
        start "" "$dd" 2>/dev/null || "$dd" &>/dev/null &
      else
        echo "Error: Could not find Docker Desktop. Please start it manually."
        exit 1
      fi
      ;;
    Darwin)
      open -a "Docker" 2>/dev/null || open -a "Docker Desktop" 2>/dev/null || {
        echo "Error: Could not find Docker Desktop. Please start it manually."
        exit 1
      }
      ;;
    Linux)
      if command -v systemctl &>/dev/null; then
        sudo systemctl start docker 2>/dev/null || {
          echo "Error: Could not start Docker. Run: sudo systemctl start docker"
          exit 1
        }
      else
        echo "Error: Docker is not running. Please start the Docker daemon."
        exit 1
      fi
      ;;
  esac

  # Wait for Docker to be ready (up to 60 seconds)
  echo -n "Waiting for Docker"
  for i in $(seq 1 30); do
    if docker info &>/dev/null 2>&1; then
      echo " ready!"
      return 0
    fi
    echo -n "."
    sleep 2
  done
  echo ""
  echo "Error: Docker did not start in time. Please start Docker Desktop manually."
  exit 1
}

# Wrapper that handles paths with spaces correctly
compose() {
  if [ -f "$PROJECT_DIR/docker-compose.local.yml" ] && grep -q "APP_MODE=local" "$PROJECT_DIR/.env" 2>/dev/null; then
    docker compose -f "$PROJECT_DIR/docker-compose.yml" -f "$PROJECT_DIR/docker-compose.local.yml" "$@"
  else
    docker compose -f "$PROJECT_DIR/docker-compose.yml" "$@"
  fi
}

CMD="${1:-help}"
shift 2>/dev/null || true

case "$CMD" in
  start)
    ensure_docker
    echo "Starting WP Launcher..."
    compose up -d "$@"
    echo "Running at http://localhost"
    ;;

  stop)
    ensure_docker
    echo "Stopping WP Launcher..."
    compose down "$@"
    ;;

  restart)
    ensure_docker
    echo "Restarting WP Launcher..."
    compose restart "$@"
    ;;

  rebuild)
    ensure_docker
    echo "Rebuilding and restarting WP Launcher..."
    compose up -d --build "$@"
    ;;

  update|upgrade)
    echo "Updating WP Launcher..."
    bash "$PROJECT_DIR/scripts/update.sh"
    ;;

  version|--version|-v)
    if [ -f "$PROJECT_DIR/version.json" ]; then
      VER=$(node -p "require('$PROJECT_DIR/version.json').version" 2>/dev/null || echo "unknown")
      COMMIT=$(node -p "require('$PROJECT_DIR/version.json').commit" 2>/dev/null || echo "unknown")
      echo "WP Launcher v${VER} (${COMMIT})"
    else
      VER=$(node -p "require('$PROJECT_DIR/package.json').version" 2>/dev/null || echo "unknown")
      echo "WP Launcher v${VER}"
    fi
    ;;

  status|ps)
    ensure_docker
    compose ps "$@"
    ;;

  logs)
    ensure_docker
    compose logs -f "$@"
    ;;

  sites)
    # List active sites from the API
    SITES=$(curl -sf http://localhost:${API_PORT}/api/sites 2>/dev/null || curl -sf http://localhost/api/sites 2>/dev/null || echo "")
    if [ -z "$SITES" ]; then
      echo "Could not reach API. Is WP Launcher running? (wpl start)"
      exit 1
    fi
    echo "$SITES" | python3 -m json.tool 2>/dev/null || echo "$SITES"
    ;;

  build:wp)
    ensure_docker
    echo "Building WordPress images (all PHP versions)..."
    bash "$PROJECT_DIR/scripts/build-wp-image.sh" "$@"
    ;;

  shell)
    ensure_docker
    # Open a shell in a running WordPress container
    CONTAINER="${1:-}"
    if [ -z "$CONTAINER" ]; then
      echo "Usage: wpl shell <subdomain>"
      echo ""
      echo "Running WordPress containers:"
      docker ps --filter "label=wp-launcher.managed=true" --format "  {{.Names}}" | sed 's/wp-site-//'
      exit 1
    fi
    echo "Opening shell in wp-site-${CONTAINER}..."
    docker exec -it "wp-site-${CONTAINER}" bash
    ;;

  wp)
    ensure_docker
    # Run WP-CLI in a WordPress container
    CONTAINER="${1:-}"
    if [ -z "$CONTAINER" ]; then
      echo "Usage: wpl wp <subdomain> <wp-cli command...>"
      echo "Example: wpl wp coral-sunset-7x3k plugin list"
      echo ""
      echo "Running WordPress containers:"
      docker ps --filter "label=wp-launcher.managed=true" --format "  {{.Names}}" | sed 's/wp-site-//'
      exit 1
    fi
    shift
    docker exec -it "wp-site-${CONTAINER}" wp --allow-root "$@"
    ;;

  open)
    # Open a site or the dashboard in the browser
    TARGET="${1:-dashboard}"
    if [ "$TARGET" = "dashboard" ]; then
      URL="http://localhost"
    elif [ "$TARGET" = "mail" ] || [ "$TARGET" = "mailpit" ]; then
      URL="http://localhost:8025"
    else
      URL="http://${TARGET}.localhost"
    fi
    echo "Opening $URL..."
    if command -v xdg-open &>/dev/null; then xdg-open "$URL" 2>/dev/null &
    elif command -v open &>/dev/null; then open "$URL" 2>/dev/null &
    elif command -v start &>/dev/null; then start "$URL" 2>/dev/null &
    else echo "  $URL"; fi
    ;;

  admin:promote)
    EMAIL="${1:-}"
    if [ -z "$EMAIL" ]; then
      echo "Usage: wpl admin:promote <email>"
      exit 1
    fi
    API_KEY=$(grep -E '^API_KEY=' "$PROJECT_DIR/.env" 2>/dev/null | cut -d= -f2- | tr -d '"' | tr -d "'")
    if [ -z "$API_KEY" ]; then
      echo "Error: Could not read API_KEY from .env"
      exit 1
    fi
    RESULT=$(curl -sf -X POST "http://localhost:${API_PORT}/api/admin/users/promote" \
      -H "X-API-Key: $API_KEY" \
      -H "Content-Type: application/json" \
      -d "{\"email\": \"$EMAIL\", \"role\": \"admin\"}" 2>/dev/null)
    if [ $? -eq 0 ]; then
      echo "$RESULT" | python3 -c "import sys,json; print(json.load(sys.stdin).get('message','Done'))" 2>/dev/null || echo "$RESULT"
    else
      echo "Error: Could not reach API. Is WP Launcher running?"
      exit 1
    fi
    ;;

  admin:demote)
    EMAIL="${1:-}"
    if [ -z "$EMAIL" ]; then
      echo "Usage: wpl admin:demote <email>"
      exit 1
    fi
    API_KEY=$(grep -E '^API_KEY=' "$PROJECT_DIR/.env" 2>/dev/null | cut -d= -f2- | tr -d '"' | tr -d "'")
    if [ -z "$API_KEY" ]; then
      echo "Error: Could not read API_KEY from .env"
      exit 1
    fi
    RESULT=$(curl -sf -X POST "http://localhost:${API_PORT}/api/admin/users/promote" \
      -H "X-API-Key: $API_KEY" \
      -H "Content-Type: application/json" \
      -d "{\"email\": \"$EMAIL\", \"role\": \"user\"}" 2>/dev/null)
    if [ $? -eq 0 ]; then
      echo "$RESULT" | python3 -c "import sys,json; print(json.load(sys.stdin).get('message','Done'))" 2>/dev/null || echo "$RESULT"
    else
      echo "Error: Could not reach API. Is WP Launcher running?"
      exit 1
    fi
    ;;

  code)
    # Open a site's wp-content directory in VS Code
    SUBDOMAIN="${1:-}"
    if [ -z "$SUBDOMAIN" ]; then
      echo "Usage: wpl code <subdomain>"
      echo "Opens the site's wp-content folder in VS Code for direct editing."
      echo ""
      echo "Running WordPress containers:"
      docker ps --filter "label=wp-launcher.managed=true" --format "  {{.Names}}" | sed 's/wp-site-//'
      exit 1
    fi
    SITES_PATH=$(grep -E '^SITES_HOST_PATH=' "$PROJECT_DIR/.env" 2>/dev/null | cut -d= -f2- | tr -d '"' | tr -d "'")
    if [ -z "$SITES_PATH" ]; then
      echo "Error: SITES_HOST_PATH is not set in .env"
      echo "Set it to enable direct file access (e.g., SITES_HOST_PATH=/path/to/wp-launcher/sites)"
      exit 1
    fi
    TARGET="$SITES_PATH/$SUBDOMAIN"
    if [ ! -d "$TARGET" ]; then
      echo "Error: Site directory not found: $TARGET"
      echo "The site may not exist or may not have been created with SITES_HOST_PATH enabled."
      exit 1
    fi
    echo "Opening in VS Code: $TARGET"
    code "$TARGET"
    ;;

  browse)
    # Open a site's wp-content directory in the system file manager
    SUBDOMAIN="${1:-}"
    if [ -z "$SUBDOMAIN" ]; then
      echo "Usage: wpl browse <subdomain>"
      echo "Opens the site's wp-content folder in the system file manager."
      echo ""
      echo "Running WordPress containers:"
      docker ps --filter "label=wp-launcher.managed=true" --format "  {{.Names}}" | sed 's/wp-site-//'
      exit 1
    fi
    SITES_PATH=$(grep -E '^SITES_HOST_PATH=' "$PROJECT_DIR/.env" 2>/dev/null | cut -d= -f2- | tr -d '"' | tr -d "'")
    if [ -z "$SITES_PATH" ]; then
      echo "Error: SITES_HOST_PATH is not set in .env"
      exit 1
    fi
    TARGET="$SITES_PATH/$SUBDOMAIN"
    if [ ! -d "$TARGET" ]; then
      echo "Error: Site directory not found: $TARGET"
      exit 1
    fi
    echo "Opening: $TARGET"
    if command -v explorer.exe &>/dev/null; then explorer.exe "$(wslpath -w "$TARGET" 2>/dev/null || echo "$TARGET")" 2>/dev/null &
    elif command -v xdg-open &>/dev/null; then xdg-open "$TARGET" 2>/dev/null &
    elif command -v open &>/dev/null; then open "$TARGET" 2>/dev/null &
    else echo "  $TARGET"; fi
    ;;

  dir)
    echo "$PROJECT_DIR"
    ;;

  help|--help|-h|"")
    echo "WP Launcher CLI"
    echo ""
    echo "Usage: wpl <command> [options]"
    echo ""
    echo "Commands:"
    echo "  start              Start all services"
    echo "  stop               Stop all services"
    echo "  restart            Restart all services"
    echo "  rebuild            Rebuild and restart (after code changes)"
    echo "  update             Pull latest code, rebuild, and restart"
    echo "  version            Show current version"
    echo "  status             Show running containers"
    echo "  logs [service]     Tail logs (optionally for a specific service)"
    echo "  sites              List active WordPress sites"
    echo "  open [target]      Open in browser (dashboard, mail, or subdomain)"
    echo "  shell <subdomain>  Open bash shell in a site container"
    echo "  wp <subdomain> ... Run WP-CLI command in a site container"
    echo "  code <subdomain>   Open site's wp-content in VS Code"
    echo "  browse <subdomain> Open site's wp-content in file manager"
    echo "  build:wp           Rebuild WordPress images (all PHP versions)"
    echo "  admin:promote <email>  Promote a user to admin"
    echo "  admin:demote <email>   Demote an admin to user"
    echo "  dir                Print WP Launcher project directory"
    echo "  help               Show this help"
    echo ""
    echo "Examples:"
    echo "  wpl start                          # Start WP Launcher"
    echo "  wpl logs api                       # Tail API logs"
    echo "  wpl open coral-sunset-7x3k         # Open site in browser"
    echo "  wpl code coral-sunset-7x3k         # Edit wp-content in VS Code"
    echo "  wpl wp coral-sunset-7x3k plugin list   # List plugins via WP-CLI"
    echo "  wpl shell coral-sunset-7x3k        # SSH into site container"
    ;;

  *)
    echo "Unknown command: $CMD"
    echo "Run 'wpl help' for available commands."
    exit 1
    ;;
esac
