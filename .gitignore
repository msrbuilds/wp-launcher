# Claude Code local settings
.claude/settings.local.json

# Dependencies
node_modules/

# Build output
dist/
packages/dashboard/dist/
packages/api/dist/

# Environment & secrets
.env
.env.local
.env.production

# Database
data/

# Site wp-content bind mounts
sites/
*.db
*.db-shm
*.db-wal

# Traefik SSL certificates
traefik/acme.json

# Product assets — only track .zip files, ignore extracted directories
product-assets/**/plugins/*/
product-assets/**/themes/*/
!product-assets/**/*.zip
!product-assets/**/demo-content.xml

# Products — only track defaults and demos
products/*
!products/_default.json
!products/demo-*.json

# Templates — only track defaults
templates/*
!templates/.gitkeep
# OS files
.DS_Store
Thumbs.db
desktop.ini

# IDE
.vscode/
.idea/
*.swp
*.swo
*~

# Logs
*.log
npm-debug.log*

# Plans, reports & tests
plans/
reports/
tests/

# Docker
docker-compose.override.yml

# Extensions — only track installable/distributable files
extensions/
!extensions/dist/
!extensions/dist/**

# Generated
version.json
packages/api/version.json
