FROM node:22-alpine

WORKDIR /app

COPY package.json package-lock.json* ./
RUN npm install --production=false

COPY tsconfig.json ./
COPY src/ ./src/

RUN npm run build

# Include version.json if present (generated by scripts/generate-version.sh)
# Falls back to package.json version at runtime if missing
COPY version.jso[n] ./

ENV NODE_ENV=production
EXPOSE 3737

CMD ["node", "dist/index.js"]
