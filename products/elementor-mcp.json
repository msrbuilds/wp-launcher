{
  "id": "elementor-mcp",
  "name": "Elementor MCP",
  "wordpress": {
    "version": "6.9",
    "locale": "en_US"
  },
  "plugins": {
    "preinstall": [
      {
        "source": "local",
        "path": "./product-assets/elementor-mcp/plugins/elementor",
        "activate": true
      },
      {
        "source": "local",
        "path": "./product-assets/elementor-mcp/plugins/mcp-adapter",
        "activate": true
      },
      {
        "source": "local",
        "path": "./product-assets/elementor-mcp/plugins/elementor-mcp",
        "activate": true
      }
    ],
    "remove": ["hello", "akismet"]
  },
  "themes": {
    "install": [],
    "remove": []
  },
  "demo": {
    "default_expiration": "1h",
    "max_expiration": "24h",
    "max_concurrent_sites": 5,
    "admin_user": "demo",
    "admin_password": "demo123",
    "admin_email": "demo@example.com",
    "landing_page": "/wp-admin/options-general.php?page=elementor-mcp"
  },
  "restrictions": {
    "disable_file_mods": true,
    "hidden_menu_items": ["tools.php"],
    "blocked_capabilities": [
      "install_plugins",
      "install_themes",
      "edit_plugins",
      "edit_themes",
      "update_core",
      "export",
      "import"
    ]
  },
  "docker": {
    "image": "wp-launcher/elementor-mcp:latest"
  },
  "branding": {
    "banner_text": "Welcome to the Elementor MCP demo! Expires in {time_remaining}.",
    "logo_url": "",
    "description": "Try Elementor MCP Server plugin in a safe environment.",
    "image_url": "https://msrbuilds.com/wp-content/uploads/2026/03/system_12392275.png"
  }
}
