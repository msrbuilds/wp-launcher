{
  "id": "5dp-backup-engine",
  "name": "5DP Backup Engine",
  "wordpress": {
    "version": "6.9",
    "locale": "en_US"
  },
  "plugins": {
    "preinstall": [
      {
        "source": "local",
        "path": "./product-assets/5dp-backup-engine/plugins/5dp-backup-restore",
        "activate": true
      }
    ],
    "remove": ["hello", "akismet"]
  },
  "themes": {
    "install": [],
    "remove": []
  },
  "demo": {
    "default_expiration": "2h",
    "max_expiration": "24h",
    "max_concurrent_sites": 5,
    "admin_user": "demo",
    "admin_password": "demo123",
    "admin_email": "demo@example.com",
    "landing_page": "/wp-admin/admin.php?page=fdpbr"
  },
  "restrictions": {
    "disable_file_mods": true,
    "hidden_menu_items": ["tools.php"],
    "blocked_capabilities": [
      "install_plugins",
      "install_themes",
      "edit_plugins",
      "edit_themes",
      "update_core",
      "export",
      "import"
    ]
  },
  "docker": {
    "image": "wp-launcher/5dp-backup-engine:latest"
  },
  "branding": {
    "banner_text": "Welcome to the 5DP Backup Engine demo! Expires in {time_remaining}.",
    "logo_url": "",
    "description": "Try 5DP Backup Engine — the most popular WordPress backup solution with 5+ million active installations.",
    "image_url": "https://msrbuilds.com/wp-content/uploads/2026/03/automatic_18158185.png"
  }
}
